# Image target: GCE + Intel TDX, with sm overlay on top of easyenclave.
#
# Fork of easyenclave/image/targets/gcp/profile.env. Adds an overlay step
# that copies ../overlay/ onto the base rootfs before UKI packaging.
#
# Builds GCE image family `slopandmop-stable`. See .github/workflows/image.yml.
#
# TODO: scaffold only — fill in based on the upstream easyenclave gcp target.
# Critical knobs:
#   BASE_IMAGE=easyenclave-stable          # start from the current ee stable
#   OVERLAY_DIR=../overlay                 # layered on top before UKI pack
#   IMAGE_FAMILY=slopandmop-stable
#   EXTRA_PACKAGES="tmux jq"               # alongside the baked claude-code+gcloud
#   GUEST_FEATURES="UEFI_COMPATIBLE,TDX_CAPABLE,GVNIC"
